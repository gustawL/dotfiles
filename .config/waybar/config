[
{
    "layer": "bottom",
    "position": "top",
    "height": 10,
    "spacing": 4,
    "name": "top",

    // Order of the modules
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["mpd"],
    "modules-right": ["network", "cpu", "memory", "temperature", "wireplumber", "clock"],

    // Modules configuration
    "hyprland/window": {
        "format": " {} ",
    },
    
    "hyprland/workspaces": {
        "on-scroll-up": "hyprctl dispatch workspace e+1",
	"on-scroll-down": "hyprctl dispatch workspace e-1",
	"disable-scroll": false,
	"on-click": "activate",
	"separate-outputs": false,
	"format": "{name}",
	"format-icons": {
	    "w1": " 1 ] Medical ",
	    "w2": " 2 ] Research ",
	    "w3": " 3 ] Maintenance ",
	    "w4": " 4 ] Storage ",
	    "w5": " 5 ] Flight Deck ",
	    "w6": " 6 ] Executive ",
	    "w7": " 7 ] Engineering ",
	    "w8": " 8 ] Security ",
	    "w9": " 9 ] Bridge ",
	    "w10": " 0] Reactor ",
	    "urgent": "",
	    "focused": "",
	    "default": ""
	},
    },
    
    "mpd": {
        "format":
        " {stateIcon} {consumeIcon} {randomIcon} {repeatIcon} {singleIcon} {artist} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) {songPosition}/{queueLength} {volume}% ",
	"format-disconnected": "Disconnected",
	"format-stopped": "Stopped",
	"unknown-tag": "",
	"interval": 2,
	"server": "127.0.0.1",
	"port": 6660,
	"consume-icons": {
	    "on": " "
	},
	"random-icons": {
	    "off": "<span color=\"#808080\"> </span>",
	    "on": " "
	},
	"repeat-icons": {
	    "off": "<span color=\"#808080\"> </span>",
	    "on": " "
	},
	"single-icons": {
	    "off": "<span color=\"#808080\">󰎤 </span>",
            "on": "󰎤 "
	},
	"state-icons": {
	    "paused": "",
            "playing": ""
        },
    },

    "clock": {
        "format": "{:%d-%m-%Y %H:%M:%S} ",
	"format-alt": "{:%Y-%m-%d}",
	"interval": 1
    },

    "cpu": {
        "format": " {usage}%",
        "tooltip": false,
        "interval": 1,
    },

    "memory": {
        "format": " {}%",
	"interval": 1,
	"tooltip-format": " {used:0.1f}/{total:0.1f} "
    },

    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 90,
        "format": "{icon} {temperatureC}°C",
        "format-icons": ["", "", ""],
	"interval": 1,
	"tooltip": false
    },
    
    "network": {
        "interface": "enp8s0", // (Optional) To force the use of this interface
        "format": "{ifname}",
	"format-ethernet": "TX: {bandwidthUpBits} RX: {bandwidthDownBits}",
        "tooltip-format": " {ifname} via {ipaddr} ",
        //"format-linked": "{ifname} (No IP) ",
        "format-disconnected": "Disconnected ...",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
	"interval": 1
    },

    "wireplumber": {
        "format": "{volume}% {icon}",
	"format-muted": "",
	"on-click": "helvum",
	"format-icons": ["", "", ""]
    },
}]